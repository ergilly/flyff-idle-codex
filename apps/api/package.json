{
  "name": "@flyff-idle/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:migrate": "tsx src/data/migrate.ts",
    "db:seed": "tsx src/data/seed.ts",
    "db:reset-test-accounts": "tsx src/data/resetTestAccounts.ts",
    "game-data:build": "tsx src/data/buildGameDataDatabase.ts",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "jest --config jest.config.cjs --runInBand --testPathPattern=\"tests/unit|src/.*\\.test\\.ts$\"",
    "test:integration": "jest --config jest.config.cjs --runInBand --testPathPattern=tests/integration",
    "test:coverage": "jest --config jest.config.cjs --coverage --runInBand"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.23.1",
    "typescript": "^5.7.2"
  }
}
