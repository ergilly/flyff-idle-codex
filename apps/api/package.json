{
  "name": "@flyff-idle/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:migrate": "tsx src/data/migrate.ts",
    "db:seed": "tsx src/data/seed.ts",
    "test": "npm run test:unit && npm run test:api",
    "test:unit": "jest --config jest.config.cjs --runInBand",
    "test:coverage": "jest --config jest.config.cjs --coverage --runInBand",
    "pretest:api": "npm run allure:clean",
    "test:api": "playwright test --config playwright.config.ts",
    "posttest:api": "npm run allure:generate",
    "allure:clean": "node -e \"require('node:fs').rmSync('test/reports/allure-results', { recursive: true, force: true })\"",
    "allure:generate": "allure generate test/reports/allure-results --clean -o test/reports/allure-report",
    "allure:open": "allure open test/reports/allure-report"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "@types/supertest": "^6.0.2",
    "allure-commandline": "^2.43.0",
    "allure-playwright": "^3.10.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
