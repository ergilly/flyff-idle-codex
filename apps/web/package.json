{
  "name": "@flyff-idle/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "npm run test:unit && npm run test:ui",
    "test:unit": "jest --config jest.config.cjs",
    "test:coverage": "jest --config jest.config.cjs --coverage",
    "pretest:ui": "npm run allure:clean",
    "test:ui": "playwright test --config playwright.config.ts --pass-with-no-tests",
    "posttest:ui": "npm run allure:generate",
    "allure:clean": "node -e \"require('node:fs').rmSync('test/reports/allure-results', { recursive: true, force: true })\"",
    "allure:generate": "allure generate test/reports/allure-results --clean -o test/reports/allure-report",
    "allure:open": "allure open test/reports/allure-report"
  },
  "dependencies": {
    "lucide-react": "^1.17.0",
    "next": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "allure-commandline": "^2.43.0",
    "allure-playwright": "^3.10.2",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.5.19",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.7.2"
  }
}
